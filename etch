#!/bin/sh
WHITE="\033[0;0m"
RED="\033[0;31m"
GREEN="\033[0;32m"
ORANGE="\033[0;33m"
BLUE="\033[0;34m"
PURPLE="\033[0;35m"
SPECIAL="\033[37;5m"

clear
echo -e "
$SPECIAL \      (_,_)   $BLUE$USER$WHITE@$RED$HOSTNAME
$SPECIAL  '---_.(,o o)  $GREEN$(uname) $(uname -m)
$SPECIAL  |     .-('.') $ORANGE$(uname -r)
$SPECIAL .''w--:|       $BLUE$XDG_CURRENT_DESKTOP
$SPECIAL   '  .  '      $PURPLE$TERM

$WHITE mem: $ORANGE$(free -h --giga | grep -Po "Mem:\s+\S+\s+\K\S+")$WHITE / $RED$(free -h --giga | grep -Po "Mem:\s+\K\S+")
$WHITE pac: $GREEN$(pacman -Q | wc -l)$WHITE
"
