#!/bin/sh
WHITE="\033[0;0m"
RED="\033[0;31m"
GREEN="\033[0;32m"
ORANGE="\033[0;33m"
BLUE="\033[0;34m"
PURPLE="\033[0;35m"
SPECIAL="\033[37;5m"

clear

echo -e "
$SPECIAL   .===============================.
$SPECIAL   |
$SPECIAL   |$WHITE ,      (___)    $BLUE$USER$WHITE@$RED$HOSTNAME
$SPECIAL   |$WHITE  \----(,o o )   $GREEN$(uname) $(uname -m)
$SPECIAL   |$WHITE  ||     _(._.)  $ORANGE$(uname -r)
$SPECIAL   |$WHITE  ||w--||'       $BLUE$XDG_CURRENT_DESKTOP
$SPECIAL   |$WHITE  ''-  ''-       $PURPLE$TERM
$SPECIAL   |
$SPECIAL   |===============================
$SPECIAL   |$WHITE  Mem: $ORANGE$(free -h --giga | grep "Mem:" | cut -d " " -f 22)$WHITE/$RED$(free -h --giga | grep "Mem:" | cut -d " " -f 14)
$SPECIAL   |$WHITE  Pac: $GREEN$(pacman -Q | wc -l)
$SPECIAL   '==============================='
"

for i in $(seq 2 11)
do
    tput cup $i 35
    echo -e "$SPECIAL|"
done

tput cup 13 0  && echo -e "$WHITE"
